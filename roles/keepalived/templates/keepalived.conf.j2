# {{ ansible_managed }}

global_defs {
    script_user root
    enable_script_security
}

# Health-check: keepalived promotes/demotes based on whether HAProxy is alive.
# weight 2  — node with running HAProxy wins the VIP election
# fall  2   — 2 consecutive failures (4 s) before marking down
# rise  1   — 1 success is enough to restore priority immediately
vrrp_script chk_haproxy {
    script "/usr/bin/systemctl is-active haproxy"
    interval 2
    weight   2
    fall     2
    rise     1
}

vrrp_instance VI_1 {
    state               {{ keepalived_state }}
    interface           {{ haproxy_vip_interface }}
    virtual_router_id   {{ keepalived_vrid }}
    priority            {{ keepalived_priority }}
    advert_int          1

    # Unicast mode — required on most cloud providers where multicast is blocked.
    # Use the IP on the same interface as the VIP (ansible_host = enp1s0 IP).
    unicast_src_ip {{ ansible_host }}
    unicast_peer {
{% for host in groups['haproxy'] %}
{% if hostvars[host]['ansible_host'] != ansible_host %}
        {{ hostvars[host]['ansible_host'] }}
{% endif %}
{% endfor %}
    }

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ haproxy_vip }}
    }

    track_script {
        chk_haproxy
    }
}
